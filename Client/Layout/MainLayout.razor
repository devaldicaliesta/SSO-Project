@inherits LayoutComponentBase
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<div class="page">
    <div class="sidebar">
        <AuthorizeView>
            <Authorized>
                <NavMenu />
            </Authorized>
        </AuthorizeView>
    </div>

    <main>
        <div class="top-row px-4 d-flex justify-content-between align-items-center">
            <div class="app-title">FundAdmin Asset Management</div>
            <div class="d-flex align-items-center">
                <AuthorizeView>
                    <Authorized>
                        <div class="user-chip me-3">
                            <div class="user-meta">
                                <div class="name">@context.User.FindFirst("name")?.Value</div>
                                <div class="role">@context.User.FindFirst("role")?.Value</div>
                            </div>
                            <div class="avatar">@GetInitials(context.User.FindFirst("name")?.Value)</div>
                        </div>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Logout(context.User)">
                            <span class="bi bi-box-arrow-right me-1"></span>Logout
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    // Two-letter initials for the avatar badge (e.g. "Andi Analyst" -> "AA").
    private static string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][..1].ToUpper()
            : (parts[0][..1] + parts[^1][..1]).ToUpper();
    }

    // The BFF issues a per-session logout URL (a "bff:logout_url" claim) that
    // carries the session id, so logout cannot be triggered cross-site. We do a
    // full-page navigation to it: the server clears the cookie + calls the IdP
    // end-session endpoint, then returns the user to the app (now logged out).
    private void Logout(ClaimsPrincipal user)
    {
        var logoutUrl = user.FindFirst("bff:logout_url")?.Value ?? "bff/logout";
        Navigation.NavigateTo(logoutUrl, forceLoad: true);
    }
}

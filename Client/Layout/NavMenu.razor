@using Shared
@inject HttpClient Http

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">
            <span class="brand-mark"><span class="bi bi-graph-up-arrow text-white"></span></span>
            FundAdmin
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

@* The menu is resolved server-side against the user's permissions (GET /api/menu).
   The client renders exactly what it is allowed to see - no hardcoded links. *@
<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        @if (_menu is not null)
        {
            @foreach (var item in _menu)
            {
                @if (item.Children.Count == 0 && item.Route is not null)
                {
                    <div class="nav-item">
                        <NavLink class="nav-link" href="@item.Route" Match="@MatchFor(item.Route)">
                            <span class="bi @item.Icon"></span> @item.Label
                        </NavLink>
                    </div>
                }
                else if (item.Children.Count > 0)
                {
                    <div class="nav-section">@item.Label</div>
                    @foreach (var child in item.Children)
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="@(child.Route ?? string.Empty)">
                                <span class="bi @child.Icon"></span> @child.Label
                            </NavLink>
                        </div>
                    }
                }
            }
        }
    </nav>
</div>

@code {
    private List<MenuItemDto>? _menu;
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _menu = await Http.GetFromJsonAsync<List<MenuItemDto>>("api/menu");
        }
        catch
        {
            // Not signed in / network error -> render nothing.
            _menu = new List<MenuItemDto>();
        }
    }

    private static NavLinkMatch MatchFor(string route) =>
        string.IsNullOrEmpty(route) ? NavLinkMatch.All : NavLinkMatch.Prefix;
}

@page "/"
@attribute [Authorize]
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject HttpClient Http

<PageTitle>Dashboard - FundAdmin Asset Management</PageTitle>

<div class="container-fluid px-0">
    @if (userProfile != null)
    {
        <div class="welcome-hero mb-4">
            <h1>Selamat datang, @userProfile.Name <span class="role-pill">@userProfile.Role</span></h1>
            <div class="sub"><span class="bi bi-envelope me-1"></span>@userProfile.Email</div>
        </div>

        <div class="stat-grid mb-4">
            <div class="stat-card">
                <div class="icon blue"><span class="bi bi-pie-chart-fill"></span></div>
                <div>
                    <div class="label">Total Fund Aktif</div>
                    <div class="value">12</div>
                    <div class="hint">Reksa Dana aktif periode ini</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="icon green"><span class="bi bi-clock-history"></span></div>
                <div>
                    <div class="label">Posisi Terakhir Diperbarui</div>
                    <div class="value">@DateTime.Now.ToString("HH:mm")</div>
                    <div class="hint">@DateTime.Now.ToString("dd MMM yyyy") &middot; waktu server</div>
                </div>
            </div>
            <div class="stat-card">
                <div class="icon amber"><span class="bi bi-activity"></span></div>
                <div>
                    <div class="label">Aktivitas Terbaru</div>
                    <div class="value">5</div>
                    <div class="hint">Transaksi hari ini</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header d-flex align-items-center">
                <span class="bi bi-shield-check me-2 text-success"></span>
                Verifikasi Sesi (GET /api/me)
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    Hasil panggilan API <code>/api/me</code> menggunakan cookie sesi BFF
                    (tanpa token di browser):
                </p>
                <pre class="api-pre"><code>@apiResult</code></pre>
                @if (isLoadingApi)
                {
                    <div class="text-center mt-3">
                        <div class="spinner-border spinner-border-sm text-primary" role="status">
                            <span class="visually-hidden">Memuat...</span>
                        </div>
                        <span class="ms-2">Memanggil API...</span>
                    </div>
                }
            </div>
        </div>
    }
    else if (isLoading)
    {
        <div class="text-center mt-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Memuat...</span>
            </div>
            <p class="mt-2 text-muted">Memuat data pengguna...</p>
        </div>
    }
</div>

@code {
    private Shared.UserProfileDto? userProfile;
    private string apiResult = "";
    private bool isLoading = true;
    private bool isLoadingApi = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity?.IsAuthenticated == true)
            {
                userProfile = new Shared.UserProfileDto
                {
                    Name = user.FindFirst("name")?.Value ?? "User",
                    Email = user.FindFirst("email")?.Value ?? "",
                    Role = user.FindFirst("role")?.Value ?? "Unknown"
                };

                await CallApiMe();
            }
        }
        catch (Exception ex)
        {
            apiResult = $"Error: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CallApiMe()
    {
        isLoadingApi = true;
        try
        {
            var response = await Http.GetAsync("api/me");

            if (response.IsSuccessStatusCode)
            {
                var profile = await response.Content.ReadFromJsonAsync<Shared.UserProfileDto>();
                apiResult = System.Text.Json.JsonSerializer.Serialize(profile,
                    new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
            }
            else
            {
                apiResult = $"HTTP {(int)response.StatusCode}: {response.ReasonPhrase}";
            }
        }
        catch (Exception ex)
        {
            apiResult = $"Exception: {ex.Message}";
        }
        finally
        {
            isLoadingApi = false;
        }
    }
}

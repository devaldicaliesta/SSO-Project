@page
@model Server.Pages.Account.MfaModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FundAdmin SSO &mdash; Two-factor</title>
    <style>
        :root { color-scheme: light; }
        * { box-sizing: border-box; }
        body {
            font-family: system-ui, "Segoe UI", Roboto, sans-serif;
            background: linear-gradient(135deg, #1e3a8a, #0f172a);
            min-height: 100vh; margin: 0;
            display: flex; align-items: center; justify-content: center;
        }
        .card {
            background: #fff; width: 100%; max-width: 420px;
            padding: 2.25rem; border-radius: 14px;
            box-shadow: 0 18px 45px rgba(0,0,0,.35);
        }
        .brand { text-align: center; margin-bottom: 1.25rem; }
        .brand h1 { font-size: 1.25rem; margin: 0; color: #0f172a; }
        .brand p { margin: .25rem 0 0; color: #64748b; font-size: .85rem; }
        .qr { text-align: center; margin: 1rem 0; }
        .qr img { width: 190px; height: 190px; border: 1px solid #e2e8f0; border-radius: 10px; padding: 6px; }
        .steps { color: #334155; font-size: .85rem; line-height: 1.45; }
        .steps ol { margin: .4rem 0 0; padding-left: 1.1rem; }
        .key {
            margin: .9rem 0; text-align: center; font-family: ui-monospace, "Cascadia Code", monospace;
            font-size: 1rem; letter-spacing: .12em; color: #0f172a;
            background: #f1f5f9; border: 1px dashed #cbd5e1; border-radius: 8px; padding: .55rem;
        }
        label { display: block; font-size: .8rem; color: #334155; margin: 1rem 0 .35rem; font-weight: 600; }
        input[type=text] {
            width: 100%; padding: .65rem .75rem; border: 1px solid #cbd5e1;
            border-radius: 8px; font-size: 1.35rem; letter-spacing: .4em; text-align: center;
        }
        input:focus { outline: 2px solid #2563eb; border-color: #2563eb; }
        button {
            margin-top: 1.25rem; width: 100%; padding: .7rem;
            background: #2563eb; color: #fff; border: 0; border-radius: 8px;
            font-size: 1rem; font-weight: 600; cursor: pointer;
        }
        button:hover { background: #1d4ed8; }
        .error {
            background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca;
            padding: .6rem .75rem; border-radius: 8px; font-size: .85rem; margin-bottom: 1rem;
        }
        .hint { margin-top: 1rem; text-align: center; color: #94a3b8; font-size: .72rem; }
        .lead-text { color: #334155; font-size: .9rem; text-align: center; margin: .25rem 0 1rem; }
        details.enroll { margin: .25rem 0 .5rem; border: 1px solid #e2e8f0; border-radius: 8px; padding: .45rem .75rem; }
        details.enroll > summary { cursor: pointer; color: #2563eb; font-size: .82rem; font-weight: 600; }
        details.enroll[open] > summary { margin-bottom: .6rem; }
    </style>
</head>
<body>
    <div class="card">
        <div class="brand">
            <h1>Verifikasi Dua Langkah</h1>
            <p>@Model.Account</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.Error))
        {
            <div class="error">@Model.Error</div>
        }

        @if (Model.AlreadyEnrolled)
        {
            <p class="lead-text">
                Buka <strong>Microsoft Authenticator</strong> dan masukkan kode 6 digit untuk akun ini.
            </p>
        }

        @* Enrollment (scan QR / manual key) is a ONE-TIME step. It is expanded for a
           first-time user and collapsed for a returning (already enrolled) one, so
           the authenticator app isn't asked to add a duplicate account every login. *@
        <details class="enroll"@(Model.AlreadyEnrolled ? "" : " open")>
            <summary>
                @(Model.AlreadyEnrolled
                    ? "Pakai perangkat baru? Tampilkan QR & kunci"
                    : "Langkah pendaftaran perangkat (sekali saja)")
            </summary>

            <div class="steps">
                Pakai <strong>Microsoft Authenticator</strong> (atau aplikasi TOTP lain):
                <ol>
                    <li>Tambah akun &rarr; <em>Other account (QR code)</em>, lalu <strong>scan QR</strong> di bawah.</li>
                    <li>Tidak bisa scan? Pilih <em>enter code manually</em> dan ketik kunci di bawah.</li>
                    <li>Masukkan kode 6 digit yang muncul di aplikasi.</li>
                </ol>
            </div>

            <div class="qr">
                <img src="@Model.QrDataUri" alt="QR code TOTP" />
            </div>

            <div class="key">@Model.ManualKey</div>
        </details>

        <form method="post">
            <label asp-for="Code">Kode 6 digit</label>
            <input asp-for="Code" type="text" inputmode="numeric" autocomplete="one-time-code"
                   maxlength="6" pattern="[0-9]*" placeholder="------" autofocus />
            <button type="submit">Verifikasi</button>
        </form>

        <p class="hint">Kode berganti tiap 30 detik. Jam perangkat harus tepat.</p>
    </div>
</body>
</html>
